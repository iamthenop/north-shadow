# tools/stamp.conf.example
# Local defaults for stamp.sh / validate.sh
# Keep values quoted where appropriate.
# Do not store PINs, passphrases, or other secrets here.

SIGNING_PROVIDER="file"
HASH_ALGORITHM="sha256"
TSA_URL="https://freetsa.org/tsr"

# TSA verification trust
# At least one trust anchor source should be set for validation.
TSA_CA_FILE="$HOME/.sign/tsa-ca.pem"
# Optional intermediates if the TSA response does not embed enough chain material.
#TSA_UNTRUSTED_FILE="$HOME/.sign/tsa-intermediates.pem"
# Optional alternative trust sources:
#TSA_CA_PATH="/etc/ssl/certs"
#TSA_CA_STORE="file:$HOME/.sign/tsa-store.pem"

# Provider: file
FILE_CERT="$HOME/.sign/sign.crt"
FILE_KEY="$HOME/.sign/sign.key"

# Provider: pkcs11
#PKCS11_MODULE="/usr/local/lib/opensc-pkcs11.so"
#PKCS11_URI="pkcs11:token=YubiKey%20PIV;object=SIGN%20key;type=private"
#PKCS11_CERT="$HOME/.sign/sign.crt"

# Provider: command
#SIGN_COMMAND="/usr/local/bin/sign-with-hsm"
#SIGN_CERT="$HOME/.sign/sign.crt"